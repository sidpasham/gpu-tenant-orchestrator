FROM alpine:3.18@sha256:de0eb0b3f2a47ba1eb89389859a9bd88b28e82f5826b6969ad604979713c2d4f AS helm-downloader
ARG TARGETARCH
RUN apk add --no-cache curl tar
RUN case "${TARGETARCH}" in \
        amd64) HELM_ARCH="amd64" ;; \
        arm64) HELM_ARCH="arm64" ;; \
        *) echo "Unsupported architecture: ${TARGETARCH}" >&2; exit 1 ;; \
    esac \
    && curl -fsSL -o helm.tar.gz "https://get.helm.sh/helm-v3.12.0-linux-${HELM_ARCH}.tar.gz" \
    && tar -zxvf helm.tar.gz \
    && mv "linux-${HELM_ARCH}/helm" /usr/local/bin/helm

FROM python:3.11-slim@sha256:ae52c5bef62a6bdd42cd1e8dffef86b9cd284bde9427da79839de7a4b983e7ca

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends libpq5 \
    && rm -rf /var/lib/apt/lists/* \
    && useradd --create-home --uid 10001 --shell /usr/sbin/nologin appuser
COPY --from=helm-downloader /usr/local/bin/helm /usr/local/bin/helm
WORKDIR /app
COPY requirements-common.txt requirements-worker.txt ./
RUN pip install --no-cache-dir -r requirements-worker.txt
COPY --chown=appuser:appuser config/ ./config
COPY --chown=appuser:appuser src/ ./src
COPY --chown=appuser:appuser helm/ ./helm
USER appuser
CMD ["python", "-m", "src.temporal.worker"]
